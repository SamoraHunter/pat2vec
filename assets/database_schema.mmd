    %% ---------------------------------------------------------
    %% SCHEMA: features
    %% ---------------------------------------------------------
    features {
        string client_idcode FK
        float dynamic_feature_columns "Many columns generated from processing"
    }

    %% ---------------------------------------------------------
    %% RELATIONSHIPS (Implicit via client_idcode)
    %% ---------------------------------------------------------
    %% 1. All data belongs to a Patient (raw_demographics)
    raw_demographics ||--o{ raw_epr_docs : "has"
    raw_demographics ||--o{ raw_mct_docs : "has"
    raw_demographics ||--o{ raw_bloods : "has"
    raw_demographics ||--o{ raw_drugs : "has"
    raw_demographics ||--o{ raw_diagnostics : "has"
    raw_demographics ||--o{ raw_news : "has"
    raw_demographics ||--o{ raw_bmi : "has"
    raw_demographics ||--o{ raw_textual_obs : "has"
    raw_demographics ||--o{ raw_reports : "has"
    raw_demographics ||--o{ raw_obs : "has"
    raw_demographics ||--o{ raw_resus : "has"
    raw_demographics ||--o{ raw_smoking : "has"
    raw_demographics ||--o{ raw_core_02 : "has"
    raw_demographics ||--o{ raw_bed : "has"
    raw_demographics ||--o{ raw_vte : "has"
    raw_demographics ||--o{ raw_hospsite : "has"
    raw_demographics ||--o{ raw_covid : "has"

    %% Appointments link via HospitalID -> client_idcode
    raw_demographics ||--o{ raw_appointments : "has (HospitalID)"

    %% 2. Annotations belong to a Patient (Denormalized link for vector creation)
    raw_demographics ||--o{ ann_epr_docs : "has annotations"
    raw_demographics ||--o{ ann_mct_docs : "has annotations"
    raw_demographics ||--o{ ann_textual_obs : "has annotations"
    raw_demographics ||--o{ ann_reports : "has annotations"

    %% 3. Annotations belong to specific Source Documents (Structural link)
    raw_epr_docs    ||--o{ ann_epr_docs : "is annotated by"
    raw_mct_docs    ||--o{ ann_mct_docs : "is annotated by"
    raw_textual_obs ||--o{ ann_textual_obs : "is annotated by"
    raw_reports     ||--o{ ann_reports : "is annotated by"

    %% 4. Final Output
    raw_demographics ||--o{ features : "produces vector"
